rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /gameStates/{userId} {
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /feedback/{feedbackId} {
      allow create: if
        request.resource.data.keys().hasOnly([
          'name',
          'email',
          'type',
          'message',
          'timestamp',
          'userAgent',
          'url'
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.type is string &&
        request.resource.data.message is string &&
        request.resource.data.userAgent is string &&
        request.resource.data.url is string &&
        request.resource.data.timestamp == request.time &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.email.size() <= 320 &&
        request.resource.data.type.size() <= 50 &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 5000 &&
        request.resource.data.userAgent.size() <= 1000 &&
        request.resource.data.url.size() <= 2000;

      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
